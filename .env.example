# ---------------------------------------------------------------------------
# Personal Dashboard – Environment Variables
# Copy this file to `.env` and fill in the values.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/dashboard?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# ---------------------------------------------------------------------------
# Secret used to encrypt the session/JWT. Generate with: `openssl rand -base64 32`
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# Public URL of the app. Required in production (e.g. https://dashboard.example.com).
# In development this defaults to http://localhost:3000.
# AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth credentials
# Create them at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# ---------------------------------------------------------------------------
# Token encryption
# 32-byte key (base64 or hex) used to encrypt OAuth tokens at rest with
# AES-256-GCM. Generate with: `openssl rand -base64 32`
# ---------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY="replace-with-openssl-rand-base64-32"
